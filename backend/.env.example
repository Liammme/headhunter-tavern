DATABASE_URL=postgresql+psycopg://bounty_pool_user:change_me@127.0.0.1:5432/bounty_pool
CORS_ORIGINS=https://your-project.vercel.app,https://www.example.com,http://localhost:3000
BOUNTY_POOL_INTELLIGENCE_LLM_ENABLED=true
BOUNTY_POOL_ESTIMATED_BOUNTY_LIVE_WRITE_ENABLED=true
BOUNTY_POOL_ESTIMATED_BOUNTY_READ_ENABLED=true
BOUNTY_POOL_JDTRUST_READ_ENABLED=false
BOUNTY_POOL_JDTRUST_ASSESSMENTS_PATH=/opt/bounty-pool/jdtrust/runtime/bounty-pool-latest-assessments.jsonl
BOUNTY_POOL_JDTRUST_TRIGGER_ENABLED=false
BOUNTY_POOL_JDTRUST_TRIGGER_COMMAND=python -m jdtrust run-latest-postgres --db runtime/bounty-pool-latest-jdtrust.db --out runtime/bounty-pool-latest-assessments.jsonl --providers rootdata,github,coinmarketcap,x,domain_dns,domain_rdap --env-file .env.local --limit 60 --timeout 12
BOUNTY_POOL_JDTRUST_TRIGGER_CWD=/opt/bounty-pool/jdtrust
BOUNTY_POOL_JDTRUST_TRIGGER_LOCK_PATH=/opt/bounty-pool/jdtrust/runtime/jdtrust-trigger.lock
BOUNTY_POOL_ZHIPU_API_KEY=change_me
BOUNTY_POOL_ZHIPU_MODEL=glm-4-flash-250414
BOUNTY_POOL_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BOUNTY_POOL_ZHIPU_FALLBACK_MODELS=glm-4-flash-250414,glm-4.7-flash
