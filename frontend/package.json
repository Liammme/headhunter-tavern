{
  "name": "bounty-pool-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "set NEXT_DIST_DIR=.next-dev&& next dev",
    "dev:reset": "node -e \"require('fs').rmSync('.next-dev',{ recursive: true, force: true })\" && set NEXT_DIST_DIR=.next-dev&& next dev",
    "build": "set NEXT_DIST_DIR=.next-build&& next build",
    "test": "vitest run"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "motion": "^12.38.0",
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/node": "20.19.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "jsdom": "25.0.1",
    "typescript": "5.5.4",
    "vitest": "3.2.4"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
